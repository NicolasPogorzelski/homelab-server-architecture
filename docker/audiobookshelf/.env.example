# ---- Basics ----
TZ=Europe/Berlin

# ---- Image pinning (recommended) ----
ABS_IMAGE=ghcr.io/advplyr/audiobookshelf
ABS_TAG=latest

# ---- Networking ----
ABS_HOST_PORT=13378

# ---- Persistent data (host paths) ----
ABS_DATA_ROOT=/opt/homelab-data/audiobookshelf

# ---- Media mounts (host paths) ----
ABS_AUDIOBOOKS_ROOT=/media/audiobookshelf/Audiobooks
ABS_PODCASTS_ROOT=/media/audiobookshelf/Podcasts
