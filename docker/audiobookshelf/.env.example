# ---- Basics ----
TZ=Europe/Berlin

# ---- Image ----
ABS_IMAGE=ghcr.io/advplyr/audiobookshelf
ABS_TAG=latest

# ---- Networking ----
ABS_HOST_PORT=13378

# ---- Persistent data (SET THIS PER ENVIRONMENT) ----
ABS_DATA_ROOT=/path/to/audiobookshelf-data

# ---- Media mounts (SET THIS PER ENVIRONMENT) ----
ABS_AUDIOBOOKS_ROOT=/path/to/audiobooks
ABS_PODCASTS_ROOT=/path/to/podcasts
