# === Compose-Level (Host paths & ports) ===
VAULTWARDEN_DATA_DIR=/path/to/vaultwarden/data
VAULTWARDEN_HOST_PORT=8080

# === Vaultwarden Core ===
VW_DATA_FOLDER=/data
DOMAIN=https://your-domain.example.com
ADMIN_TOKEN=changeme-use-a-strong-token

# === Security ===
SIGNUPS_ALLOWED=false
INVITATIONS_ALLOWED=false
WEBSOCKET_ENABLED=true

# === Logging ===
LOG_LEVEL=info
SHOW_INVITE_LINKS=true
