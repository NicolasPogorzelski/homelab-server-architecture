global:
  scrape_interval: 15s

rule_files:
  - /etc/prometheus/rules/*.yml

alerting:
  alertmanagers:
    - static_configs:
        - targets: ["127.0.0.1:9093"]

scrape_configs:
  - job_name: "prometheus"
    static_configs:
      - targets: ["127.0.0.1:9090"]

  # Node Exporter on the monitoring node (loopback-only).
  - job_name: "node"
    static_configs:
      - targets:
          - "127.0.0.1:9100"

  # Proxmox host Node Exporter (anonymized).
  - job_name: "proxmox-host-node"
    static_configs:
      - targets: ["PROXMOX_HOST_NODE_EXPORTER:9100"]

  # PostgreSQL Exporter on CT260 — scrapes pg_stat_* metrics via loopback on CT260,
  # exposed to Prometheus on CT200 via Tailscale.
  - job_name: "postgres"
    static_configs:
      - targets: ["<tailscale-ip-lxc260>:9187"]
