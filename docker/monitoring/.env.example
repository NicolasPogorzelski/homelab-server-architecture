# ---- Prometheus ----
PROM_BIND_ADDRESS=127.0.0.1
PROM_PORT=9090
PROM_RETENTION=30d
PROM_DATA=/path/to/prometheus/data

# ---- Grafana ----
GF_DATA=/path/to/grafana/data
GF_ENV_FILE=/path/to/grafana.env

# ---- Node Exporter ----
NE_BIND_ADDRESS=127.0.0.1
NE_PORT=9100

# ---- Alertmanager ----
AM_BIND_ADDRESS=<tailscale-ip-lxc200>
AM_PORT=9093
