# OpenWebUI environment configuration
# Copy to .env and fill in actual values:
#   cp .env.example .env
#   nano .env

# PostgreSQL connection string (CT260 platform database)
# Format: postgresql://<user>:<password>@<tailscale-ip>:<port>/<database>
DATABASE_URL=postgresql://openwebui_user:CHANGE_ME@<tailscale-ip-ct260>:5432/openwebui_db

# Secret key for session signing and encryption
# Generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=CHANGE_ME
