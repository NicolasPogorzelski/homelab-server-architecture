# =====================================================
# Secrets / Environment files (NEVER COMMIT)
# =====================================================

.env
.env.*
*.env
*.env.*

**/.env
**/.env.*
**/*.env
**/*.env.*

# allow env templates
!.env.example
!**/env.example

# =====================================================
# Databases / Runtime Data
# =====================================================

*.db
*.sqlite
*.sqlite3
*.sqlite3*
**/db.sqlite3*
**/data/
**/backup/

# =====================================================
# Private Keys / Certificates
# =====================================================

*.pem
*.key
*.crt
*.p12
*.pfx
**/rsa_key.pem

# =====================================================
# Logs / Temp / Cache
# =====================================================

*.log
*.tmp
*.temp
*.cache

# =====================================================
# Backups / Editor / OS junk
# =====================================================

*.bak
*.backup
*.old
*.orig
*.swp
*~
.DS_Store
Thumbs.db

# =====================================================
# Docker local overrides
# =====================================================

docker-compose.override.yml

# =====================================================
# Service configs with environment-specific values
# =====================================================
docker/monitoring/prometheus/prometheus.yml
